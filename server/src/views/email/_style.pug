style.
  body {
        background-color: #effff3;
        font-family: Arial, sans-serif;
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }
      .email-container {
        text-align: center;
        width: 100%;
        max-width: 600px;
      }
      .email-container img {
        max-width: 100%;
        height: auto;
      }
      .subject {
        font-size: 24px;
        font-weight: bold;
        margin: 20px 0;
        padding-top: 30px;
      }
      .email-content {
        background-color: #ffffff;
        padding: 20px;
        border: 1px solid;
        border-radius: 8px;
        border-color: #239742;
        margin-bottom: 20px;
      }
      .email-content p {
        margin: 10px 0;
        line-height: 1.6;
      }
      .footer-images {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .footer-images img {
        margin: 10px;
        max-width: 100px;
        height: auto;
      }