extends baseEmail

block content
  p Admin Notification:
  p A withdrawal request has been submitted by an NGO.
  ul(style="text-align: left; margin: 10px 0; padding-left: 20px;")
    li NGO Name: #{ngoName}
    li Amount: #{amount} #{currency}
    li Requested Date: #{requestDate}
  p Please review and process the request at your earliest convenience.
