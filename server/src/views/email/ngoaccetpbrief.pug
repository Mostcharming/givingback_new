extends baseEmail

block content
  p Hello #{ngoName},
  p You have successfully accepted the project "#{projectTitle}" from the donor #{donorName}.
  p
    strong Project Details:
  ul(style="text-align: left; margin: 10px 0; padding-left: 20px;")
    li Title: #{projectTitle}
    li Description: #{projectDescription}
    li Funding Amount: #{fundingAmount} #{currency}
  p Thank you for taking on this project. We wish you success in achieving its goals.
  p If you have any questions or need assistance, feel free to reach out to our support team.
