extends baseEmail

block content
  h2 New Contact Form Submission
  p You have received a new message from the contact form on the Giving Back website.
  
  table(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td
          strong Name:
        td #{name}
      tr
        td
          strong Email:
        td #{email}
      tr
        td
          strong Subject:
        td #{subject}
      tr
        td
          strong Message:
        td #{message}

  p You can reply to this email to respond to the sender directly.

  table.btn.btn-primary(role='presentation', border='0', cellpadding='0', cellspacing='0')
    tbody
      tr
        td
          a(href="mailto:#{email}" target="_blank") Reply to Sender
