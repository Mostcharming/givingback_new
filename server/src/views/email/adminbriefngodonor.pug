extends baseEmail

block content
  p Hello #{donorName},
  p A new project has been created by the admin, and your funds have been allocated to the project.
  p
    strong Project Details:
  ul(style="text-align: left; margin: 10px 0; padding-left: 20px;")
    li Title: #{projectTitle}
    li Description: #{projectDescription}
    li NGO Responsible: #{ngoName}
  p Please monitor the project progress from your dashboard.
  p If you have any questions, feel free to contact us.
