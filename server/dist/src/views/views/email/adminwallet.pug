extends baseEmail

block content
  p Admin Notification:
  p A wallet funding transaction has been completed.
  ul(style="text-align: left; margin: 10px 0; padding-left: 20px;")
    li User Name: #{userName}
    li Amount: #{amount} #{currency}
    li Transaction ID: #{transactionId}
  p Please ensure the transaction is correctly recorded in the system.
