extends baseEmail

block content
  p Admin Notification:
  p A new project has been created by #{donorName}, and the NGO "#{ngoName}" has been selected to execute it.
  p
    strong Project Details:
  ul(style="text-align: left; margin: 10px 0; padding-left: 20px;")
    li Title: #{projectTitle}
    li Description: #{projectDescription}
    li Funding Amount: #{fundingAmount} #{currency}
  p Please monitor the progress to ensure compliance with platform policies.
